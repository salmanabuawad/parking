{
  "type": "object",
  "properties": {
    "plate_detector_backend": {"type": "string", "enum": ["hsv", "yolo"]},
    "use_fast_hsv_pipeline": {"type": "boolean", "description": "Skip YOLO; use HSV only for yellow plates (faster)"},
    "hsv_lower_yellow": {"type": "array"},
    "hsv_upper_yellow": {"type": "array"},
    "plate_min_ratio": {"type": "number", "default": 1.8},
    "plate_max_ratio": {"type": "number", "default": 6.5},
    "min_plate_area": {"type": "integer", "default": 300},
    "max_plate_area_ratio": {"type": "number", "default": 0.12},
    "blur_kernel": {"type": "integer"},
    "max_track_misses": {"type": "integer"},
    "smoothing_alpha": {"type": "number"},
    "enable_ocr": {"type": "boolean"},
    "ocr_min_confidence": {"type": "number"},
    "enable_curb_detection": {"type": "boolean"},
    "registry_csv": {"type": "string"},
    "validate_plate_in_registry": {"type": "boolean", "description": "Only accept plates that exist in MoT registry"},
    "data_gov_il_resource_id": {"type": "string", "description": "MoT dataset resource ID for API fallback"}
  }
}
