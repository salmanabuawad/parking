{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlateAnalysisResult",
  "type": "object",
  "properties": {
    "validated_plate": {"type": ["string", "null"]},
    "plate_detection_reason": {"type": ["string", "null"], "description": "When plate=11111: OCR failure or not in registry"},
    "registry_match": {"type": "boolean"},
    "vehicle": {
      "type": ["object", "null"],
      "properties": {
        "manufacturer": {"type": ["string", "null"]},
        "model_name": {"type": ["string", "null"]},
        "year": {"type": ["integer", "null"]}
      }
    },
    "plate_format": {
      "type": ["object", "null"],
      "properties": {
        "name": {"type": ["string", "null"]},
        "width_cm": {"type": ["number", "null"]},
        "height_cm": {"type": ["number", "null"]}
      }
    },
    "curb": {
      "type": ["object", "null"],
      "properties": {
        "detected": {"type": "boolean"},
        "distance_px": {"type": ["number", "null"]},
        "distance_cm": {"type": ["number", "null"]}
      }
    },
    "frames_processed": {"type": "integer"},
    "debug_dir": {"type": ["string", "null"]}
  },
  "required": ["registry_match", "frames_processed"]
}
