# Postgres on same server with default credentials (user=postgres, password=postgres, db=postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
UPLOAD_DIR=./uploads
VIDEOS_DIR=./videos
SECRET_KEY=your-secret-key-change-in-production
# Set PRODUCTION=1 on the server so the backend binds to 127.0.0.1 and does not reload
PRODUCTION=1
